{
    "routes": [
      {
        "route": "/api/*",
        "rewrite": "https://image-analysis-be.azurewebsites.net/api/{*}"
      }
    ],
    "navigationFallback": {
      "rewrite": "/index.html",
      "exclude": ["/assets/*", "/api/*", "/*.{css,js,mjs,png,jpg,jpeg,svg,ico,woff,woff2,json,map}"]
    },
    "mimeTypes": {
      ".js": "application/javascript",
      ".mjs": "application/javascript",
      ".json": "application/json",
      ".css": "text/css",
      ".html": "text/html",
      ".svg": "image/svg+xml",
      ".woff": "font/woff",
      ".woff2": "font/woff2",
      ".map": "application/json"
    },
    "globalHeaders": {
      "X-Content-Type-Options": "nosniff",
      "Cache-Control": "public, max-age=31536000, immutable"
    }
  }